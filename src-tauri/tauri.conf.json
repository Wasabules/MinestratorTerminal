{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minestrator Terminal",
  "version": "0.1.1",
  "identifier": "com.geoffreylecoq.minestratorterminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Minestrator Terminal",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'; worker-src 'self' blob:",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Geoffrey Lecoq",
    "copyright": "© 2026 Geoffrey Lecoq",
    "category": "Utility",
    "homepage": "https://minestrator.com",
    "shortDescription": "Client desktop pour l'API MineStrator",
    "longDescription": "Client desktop léger et rapide pour piloter ses serveurs Minecraft via l'API MineStrator : console temps réel, SFTP natif intégré, gestion des joueurs, actions d'alimentation et onglets multi-fenêtres.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Wasabules/MinestratorTerminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4RDY4QkIwN0JBOTBEQTgKUldTb0RhbDdzSXZXeU5QWTBWb2I4Z0JlWVVqVlF6THVzUzFZdzJPS01aM3BLOGdLM1dWMk1qQVMK"
    }
  }
}
